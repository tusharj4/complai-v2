# Database
DATABASE_URL=postgresql://complai:complai_secret@localhost:5432/complai_db

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256

# Datadog (optional for local dev)
DATADOG_API_KEY=
DATADOG_APP_KEY=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Slack (optional - for critical alerts)
SLACK_WEBHOOK_URL=

# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
